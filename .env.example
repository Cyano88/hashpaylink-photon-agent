HASH_PAYLINK_BASE_URL=https://hashpaylink.com

# Telegram Bot API token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Photon credentials. Stored for Photon/Spectrum provider wiring and grant demo config.
PHOTON_PROJECT_ID=
PHOTON_SECRET_KEY=

# Optional fallback recipient addresses used only when a Telegram user has not saved their own address.
# Public users should normally run /setevm or /setsol in Telegram.
# Use public merchant addresses only. Never put private keys here.
DEFAULT_EVM_ADDRESS=
DEFAULT_SOLANA_ADDRESS=

# base | arbitrum | solana
DEFAULT_NETWORK=base

# Optional Telegram bot or community URL used by Hash PayLink pages to send
# Telegram-created users back to the bot instead of the main web create page.
TELEGRAM_RETURN_URL=https://t.me/your_bot_username

# JSON profile storage for Telegram user recipient settings.
STORE_PATH=./data/profiles.json

# Optional email alerts for Polymarket open positions at or below -30% PnL.
# Uses SendGrid's Mail Send API; no SMTP credentials or private keys are required.
EMAIL_ENABLED=false
SENDGRID_API_KEY=
ALERT_FROM_EMAIL=alerts@yourdomain.com
ALERT_FROM_NAME=Hash PayLink Alerts
ALERT_REPLY_TO_EMAIL=
POLYMARKET_ALERT_INTERVAL_MINUTES=60
